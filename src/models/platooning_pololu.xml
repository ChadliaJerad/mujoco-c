  <!-- ───────── ACTUATORS ───────── -->
  <!--
    Two actuators per robot matching exactly what the LF program looks up:
      forward1/2/3 → velocity on slide joint (linear motion, m/s)
      turn1/2/3    → velocity on hinge joint (yaw rate, rad/s)

    ctrlrange -1..1 maps to:
      forward: ±0.3 m/s   (gear=0.3)
      turn:    ±3.5 rad/s (gear=3.5)

    Think of gear as a scale factor — like a PWM-to-speed constant
    in your motor driver firmware.
  -->
  <actuator>
    <!-- Car 1 -->
    <velocity name="forward1" joint="car1_slide" kv="2.0" gear="0.3"
              ctrllimited="true" ctrlrange="-1 1"/>
    <velocity name="turn1"    joint="car1_hinge" kv="0.5" gear="3.5"
              ctrllimited="true" ctrlrange="-1 1"/>

    <!-- Car 2 -->
    <velocity name="forward2" joint="car2_slide" kv="2.0" gear="0.3"
              ctrllimited="true" ctrlrange="-1 1"/>
    <velocity name="turn2"    joint="car2_hinge" kv="0.5" gear="3.5"
              ctrllimited="true" ctrlrange="-1 1"/>

    <!-- Car 3 -->
    <velocity name="forward3" joint="car3_slide" kv="2.0" gear="0.3"
              ctrllimited="true" ctrlrange="-1 1"/>
    <velocity name="turn3"    joint="car3_hinge" kv="0.5" gear="3.5"
              ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>

  <!-- ───────── SENSORS ───────── -->
  <!--
    Exactly the sensor names the LF program looks up via mj_name2id:
      pos_car1/2/3    → subtreecom: 3D center-of-mass position (dim=3)
      linvel_car1/2/3 → velocimeter on imu site: 3D linear velocity (dim=3)

    The LF code reads:
      sensordata[pos_addr + 0] = x
      sensordata[pos_addr + 1] = y
      sensordata[pos_addr + 2] = z
  -->
