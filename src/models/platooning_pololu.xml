<!--
  MuJoCo MJCF: platooning_pololu.xml
  ===================================
  Three Pololu 3pi+ 2040 robots in a platooning formation.
  Designed to match exactly what Platooning.lf expects:

  ACTUATORS (per robot):
    forward1, forward2, forward3  — linear speed command  (m/s, range -1..1 mapped to ±MAX_SPEED)
    turn1,    turn2,    turn3     — angular speed command (rad/s, range -1..1)

  SENSORS (per robot):
    pos_car1,    pos_car2,    pos_car3    — subtreecom  (3D position, dim=3)
    linvel_car1, linvel_car2, linvel_car3 — velocimeter (3D linear vel, dim=3)

  CONTROL INTERFACE
  -----------------
  The LF program sets:
    ctrl[forwardIdx] = forward value  (-1..1)
    ctrl[turnIdx]    = turn value     (-1..1)

  We implement this with two velocity actuators per robot:
    forward actuator → drives BOTH wheels equally      (v_L = v_R = forward * MAX_SPEED)
    turn    actuator → drives wheels differentially    (v_L -= turn*TURN_GAIN, v_R += turn*TURN_GAIN)

  Since MuJoCo velocity actuators act on a single joint, we model
  forward/turn as actuators on two virtual "mixing joints" and use
  a transmission gear to distribute to left/right wheels.

  SIMPLER ALTERNATIVE (used here):
  Use a slide+hinge free body with two standard velocity actuators
  whose combined effect produces the unicycle motion.
  Each robot has:
    - A slide joint (Y axis) for forward motion   → "forward" actuator
    - A hinge joint (Z axis) for turning          → "turn" actuator
  The wheels are visual only (no drive joints) to keep the control
  interface exactly matching what the LF expects (2 actuators, not 4).

  ROBOT LAYOUT:
    car1 at x=0.0  (leader)
    car2 at x=0.3  (follower 1, 30cm behind)
    car3 at x=0.6  (follower 2, 60cm behind)
    All facing +X direction initially.

  GEOMETRY: same as 3pi_plus_2040.xml
    Chassis: cylinder 97mm dia, spawn z=0.016
    Wheels:  32x7mm, radius 16mm
    Caster:  6.35mm radius, offset -0.00965
-->

<mujoco model="platooning_pololu">

  <compiler angle="radian" inertiafromgeom="true"/>

  <option timestep="0.002"
          gravity="0 0 -9.81"
          integrator="RK4"
          cone="elliptic"/>

  <default>
    <joint damping="0.001" frictionloss="0.0005"/>
    <geom condim="4" friction="0.8 0.01 0.01" solref="0.004 1" solimp="0.99 0.999 0.0001"/>
  </default>

  <!-- ───────── ASSETS ───────── -->
  <asset>
    <material name="ground_mat"  rgba="1 1 1 1" reflectance="0.15"/>
    <material name="line_mat"    rgba="0 0 0 1"/>
    <material name="chassis1"    rgba="0.15 0.15 0.8 1"/>   <!-- blue  — leader   -->
    <material name="chassis2"    rgba="0.15 0.7  0.15 1"/>  <!-- green — follower1 -->
    <material name="chassis3"    rgba="0.8  0.15 0.15 1"/>  <!-- red   — follower2 -->
    <material name="wheel_mat"   rgba="0.1  0.1  0.1  1"/>
    <material name="caster_mat"  rgba="0.7  0.7  0.7  1"/>
    <material name="bumper_mat"  rgba="0.2  0.2  0.2  0.8"/>
  </asset>

  <!-- ───────── WORLD ───────── -->
  <worldbody>

    <geom name="floor" type="plane" size="5 5 0.1"
          material="ground_mat" friction="0.8 0.01 0.01" condim="3"/>

    <!-- ── LIGHTS ─────────────────────────────────────────────────────── -->
    <!-- Directional sun-like light from above-front -->
    <light name="sun" directional="true" pos="0 0 3"
           dir="0.2 -0.3 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"
           castshadow="true"/>
    <!-- Ambient fill light from above to avoid harsh shadows -->
    <light name="fill" directional="true" pos="0 0 2"
           dir="-0.1 0.2 -1" diffuse="0.4 0.4 0.4" specular="0 0 0"
           castshadow="false"/>

