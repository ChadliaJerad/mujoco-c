      <!--
        Two joints give us the unicycle DOF:
          slide Y  → forward/back in the robot's local frame
          hinge Z  → turning (yaw)
        This is like splitting a joystick into two axes —
        one stick controls speed, the other controls heading.
      -->
      <joint name="car1_slide" type="slide" axis="1 0 0"
             damping="0.5" frictionloss="0.1"/>
      <joint name="car1_hinge" type="hinge" axis="0 0 1"
             damping="0.05" frictionloss="0.01"/>

